{
	"SecretKey": "test",
	"AutoAccount": true,
	"SkipHostResolve": false,
	"InternalNetwork": {
		"Host": "*",
		"Port": 1234
	},
	"Network": {
		"Host": "*",
		"NumConnections": 10,
		"Port": 1237
	},
	"AntiMultiLogin": {
		"Enabled": true,
		"PreventMultipleIpConnections": true,
		"PreventMultipleAccountConnections": true,
		"DisconnectPreviousConnection": true,
		"ExemptIps": [
			"127.0.0.1",
			"::1"
		],
		"MaxConnectionsPerIp": 1
	},
	"Connections": {
		"MySQLProvider": {
			"Database": "aaemu_login",
			"Host": "%db_host%",
			"Password": "%db_password%",
			"Port": "%db_port%",
			"User": "%db_user%"
		}
	}
}